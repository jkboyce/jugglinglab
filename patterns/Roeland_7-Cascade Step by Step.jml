</line>

<line display=""/>
<line display="🔮🔮🔮 🔮🔮"/>

<line display="777720" notation="siteswap">
pattern=777720;colors=mixed
</line>

<line display="72727" notation="siteswap">
pattern=72727;colors=mixed
</line>

<line display="771" notation="siteswap">
pattern=771;colors=mixed
</line>

<line display="7777070" notation="siteswap">
pattern=7777070;colors=mixed
</line>

<line display="7770770" notation="siteswap">
