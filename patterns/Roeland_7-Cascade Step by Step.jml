</line>

<line display="71 both directions" notation="siteswap">
pattern=7272(71^5)2;colors=mixed
</line>

<line display="7070707" notation="siteswap">
pattern=7070707;colors=mixed
</line>

<line display="7707700" notation="siteswap">
