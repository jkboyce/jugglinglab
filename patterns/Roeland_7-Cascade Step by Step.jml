</line>

<line display="5 balls out of a 7-Cascade" notation="siteswap">
pattern=7777700;colors=mixed
</line>

<line display=""/>
<line display="🔮🔮🔮 🔮🔮🔮"/>

<line display="75" notation="siteswap">
