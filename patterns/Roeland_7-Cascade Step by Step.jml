<?xml version="1.0"?>
<!DOCTYPE jml SYSTEM "file://jml.dtd">
<jml version="3">
<patternlist>
<title>Roeland&apos;s 7-Cascade Step By Step</title>

<line display="Learn the 5-Cascade first before"/>
<line display="starting this list."/>

<line display=""/>
<line display="🔮🔮🔮"/>

<line display="7070700" notation="siteswap">
pattern=7070700;colors=mixed
</line>

<line display="3 balls out of a 7-Cascade" notation="siteswap">
pattern=7770000;colors=mixed
</line>

<line display=""/>
<line display="🔮🔮🔮 🔮"/>

<line display="71" notation="siteswap">
