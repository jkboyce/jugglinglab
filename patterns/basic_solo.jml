</event>
<event x="-10" y="0" z="0" t="0.6926" hand="1:left">
<throw path="1" type="toss"/>
</event>
<event x="10" y="0" z="0" t="0.9235" hand="1:right">
<throw path="2" type="toss"/>
</event>
<event x="-32.5" y="0" z="0" t="0.9235" hand="1:left">
<catch path="3"/>
</event>
<event x="30" y="0" z="35" t="1.1544" hand="1:right">
