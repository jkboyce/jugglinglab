<line display="3-ball Flash" notation="jml">
<pattern>
<title>3-ball Flash</title>
<basepattern notation="siteswap">pattern=333355500</basepattern>
<prop type="ball"/>
<setup jugglers="1" paths="3" props="1,1,1"/>
<symmetry type="delay" pperm="(1,3,2)" delay="4.4269"/>
<symmetry type="switchdelay" jperm="(1,1*)" pperm="(1,2,3)"/>
<event x="10" y="0" z="0" t="0" hand="1:right">
<throw path="1" type="toss"/>
</event>
<event x="-32.5" y="0" z="0" t="0" hand="1:left">
<catch path="2"/>
</event>
<event x="32.5" y="0" z="0" t="0.2459" hand="1:right">
<catch path="3"/>
</event>
<event x="-10" y="0" z="0" t="0.2459" hand="1:left">
<throw path="2" type="toss"/>
</event>
<event x="10" y="0" z="0" t="0.4918" hand="1:right">
<throw path="3" type="toss"/>
</event>
<event x="-32.5" y="0" z="0" t="0.4918" hand="1:left">
<catch path="1"/>
</event>
<event x="32.5" y="0" z="0" t="0.7378" hand="1:right">
<catch path="2"/>
</event>
<event x="-10" y="0" z="0" t="0.7378" hand="1:left">
<throw path="1" type="toss"/>
</event>
<event x="10" y="0" z="0" t="0.9837" hand="1:right">
<throw path="2" type="toss"/>
</event>
<event x="-32.5" y="0" z="0" t="0.9837" hand="1:left">
<catch path="3"/>
</event>
<event x="32.5" y="0" z="0" t="1.2297" hand="1:right">
<catch path="1"/>
</event>
<event x="-10" y="0" z="0" t="1.2297" hand="1:left">
<throw path="3" type="toss"/>
</event>
<event x="-17.305" y="0" z="34.2599" t="1.4444" hand="1:left"/>
<event x="10" y="0" z="0" t="1.4756" hand="1:right">
<throw path="1" type="toss"/>
</event>
<event x="19.4743" y="0" z="33.86" t="1.702" hand="1:right"/>
<event x="-32.5" y="0" z="0" t="1.9675" hand="1:left">
<catch path="2"/>
</event>
</pattern>
</line>

