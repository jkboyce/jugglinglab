<line display="Eating an apple" notation="jml">
<pattern>
<title>Eating an apple</title>
<basepattern notation="siteswap">pattern=33333423;dwell=1.0;bps=3.572;hands=(-7.5,20)(32.5).(10)(32.5).(10)(32.5).(10)(32.5).(10)(30,35).(5)(32.5).(0,35)(0,30).(-10)(32.5).;title=Eating an Apple (for light eaters)</basepattern>
