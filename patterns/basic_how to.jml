<event x="-29.8153" y="0" z="21.5003" t="0.1405" hand="1:left"/>
<event x="32.5" y="0" z="0" t="0.2008" hand="1:right">
<catch path="2"/>
</event>
<event x="10" y="0" z="0" t="0.4016" hand="1:right">
