<line display="Throw 4 out of 5" notation="jml">
<pattern>
<title>Throw 4 out of 5</title>
<basepattern notation="siteswap">pattern=[52][52]55022[22][22];title=Throw 4 out of 5</basepattern>
<prop type="ball"/>
<setup jugglers="1" paths="4" props="1,1,1,1"/>
<symmetry type="delay" pperm="(1)(2)(3)(4)" delay="3.6144"/>
<symmetry type="switchdelay" jperm="(1,1*)" pperm="(1,2)(3,4)"/>
<event x="10" y="0" z="0" t="0" hand="1:right">
<holding path="2"/>
<throw path="1" type="toss"/>
</event>
<event x="-10" y="0" z="0" t="0.2008" hand="1:left">
<holding path="4"/>
<throw path="3" type="toss"/>
</event>
<event x="10" y="0" z="0" t="0.4016" hand="1:right">
<throw path="2" type="toss"/>
</event>
<event x="-10" y="0" z="0" t="0.6024" hand="1:left">
<throw path="4" type="toss"/>
</event>
<event x="18.3978" y="0" z="17.9637" t="0.6911" hand="1:right"/>
<event x="-32.5" y="0" z="0" t="0.8032" hand="1:left">
<catch path="1"/>
</event>
<event x="32.5" y="0" z="0" t="1.004" hand="1:right">
<catch path="3"/>
</event>
<event x="-32.5" y="0" z="0" t="1.2048" hand="1:left">
<holding path="1"/>
<catch path="2"/>
</event>
<event x="32.5" y="0" z="0" t="1.4056" hand="1:right">
<holding path="3"/>
<catch path="4"/>
</event>
<event x="-21.3007" y="0" z="-16.6246" t="1.5204" hand="1:left">
<holding path="1"/>
<holding path="2"/>
</event>
<event x="20.4196" y="0" z="-16.9576" t="1.745" hand="1:right">
<holding path="3"/>
<holding path="4"/>
</event>
</pattern>
</line>

