<?xml version="1.0"?>
<!DOCTYPE jml SYSTEM "file://jml.dtd">
<jml version="3">
<patternlist>
<title>How to Juggle</title>

<line display="Learn the steps below and you&apos;ll"/>
<line display="be juggling in no time!"/>
<line display=""/>
<line display="3-Cascade Step By Step:"/>

<line display="1 Ball out of a 3-Cascade" notation="siteswap">
pattern=300;title=1 Ball out of a 3-Cascade
</line>

<line display="Throw Twice" notation="siteswap">
pattern=33022;title=Throw Twice
</line>

<line display="2 Balls out of a 3-Cascade" notation="siteswap">
pattern=330;title=2 Balls out of a 3-Cascade
</line>

<line display="Throw 3 Times" notation="siteswap">
pattern=[32]3322;title=Throw 3 Times
</line>

<line display="3-Cascade" notation="siteswap">
pattern=3
</line>

<line display="Slower 3-Cascade" notation="siteswap">
pattern=3;bps=2;title=Slower 3-Cascade
</line>

<line display=""/>
<line display="4-Fountain Step By Step:"/>

<line display="2 in One Hand" notation="siteswap">
pattern=40;title=2 in One Hand
</line>

<line display="4-Synchronous Fountain" notation="siteswap">
pattern=(4,4);title=4-Synchronous Fountain
</line>

<line display="4-Fountain" notation="siteswap">
pattern=4;title=4-Fountain
</line>

<line display=""/>
<line display="5-Cascade Step By Step:"/>

<line display="2 Balls out of a 5-Cascade" notation="jml">
<pattern>
<title>2 Balls out of a 5-Cascade</title>
<basepattern notation="siteswap">pattern=50500;title=2 Balls out of a 5-Cascade</basepattern>
<prop type="ball"/>
<setup jugglers="1" paths="2" props="1,1"/>
<symmetry type="delay" pperm="(1)(2)" delay="2.008"/>
<symmetry type="switchdelay" jperm="(1,1*)" pperm="(1)(2)"/>
<event x="10" y="0" z="0" t="0" hand="1:right">
<throw path="1" type="toss"/>
</event>
<event x="32.5" y="0" z="0" t="0.2008" hand="1:right">
<catch path="2"/>
</event>
<event x="10" y="0" z="0" t="0.4016" hand="1:right">
<throw path="2" type="toss"/>
</event>
<event x="-34.949" y="0" z="9.6431" t="0.4518" hand="1:left"/>
<event x="29.5374" y="0" z="19.7492" t="0.7028" hand="1:right"/>
<event x="-32.5" y="0" z="0" t="0.8032" hand="1:left">
<catch path="1"/>
</event>
</pattern>
</line>

<line display="3 Balls out of a 5-Cascade" notation="jml">
<pattern>
<title>3 Balls out of a 5-Cascade</title>
<basepattern notation="siteswap">pattern=52512;title=3 Balls out of a 5-Cascade</basepattern>
<prop type="ball"/>
<setup jugglers="1" paths="3" props="1,1,1"/>
<symmetry type="delay" pperm="(1)(2)(3)" delay="2.008"/>
<symmetry type="switchdelay" jperm="(1,1*)" pperm="(1)(2)(3)"/>
<event x="10" y="0" z="0" t="0" hand="1:right">
<throw path="1" type="toss"/>
</event>
<event x="-30.2705" y="0" z="-1.4657" t="0.1606" hand="1:left">
<holding path="2"/>
</event>
<event x="32.5" y="0" z="0" t="0.2008" hand="1:right">
<catch path="3"/>
</event>
<event x="10" y="0" z="0" t="0.4016" hand="1:right">
<throw path="3" type="toss"/>
</event>
<event x="-10" y="0" z="0" t="0.5321" hand="1:left">
<throw path="2" type="toss"/>
</event>
<event x="16.8658" y="0" z="0.4225" t="0.6425" hand="1:right">
<catch path="2"/>
</event>
<event x="-32.5" y="0" z="0" t="0.8032" hand="1:left">
<catch path="1"/>
</event>
</pattern>
</line>

