    <string name="gui_walkthrough_take_tour">סיור מודרך</string>
    <string name="gui_walkthrough_step_header">סיור: שלב %1$d מתוך %2$d</string>
    <string name="gui_walkthrough_exit">יציאה מהסיור</string>
    <string name="gui_walkthrough_finish">סיום</string>
    <string name="gui_walkthrough_web_note">\n\nחשוב: רשימות תבניות באפליקציית הרשת אינן נשמרות בין הפעלות הדפדפן.</string>
    <string name="gui_walkthrough_step1">ברוכים הבאים ל-Juggling Lab! זהו מסך הבית – חזור לכאן על ידי לחיצה על סמל זה. (אנא עשה זאת כדי להמשיך.)</string>
    <string name="gui_walkthrough_step2">עבור לכאן כדי לפתוח תבניות ג'אגלינג לצפייה.</string>
    <string name="gui_walkthrough_step3">עבור לכאן כדי לראות את התבניות המועדפות עליך.</string>
    <string name="gui_walkthrough_step4_touch">זוהי תצוגת האנימציה. לחץ כדי להשהות/להפעיל, גרור כדי להזיז את המצלמה, והשתמש בג'סטת צביטה בשתי אצבעות כדי להגדיל/להקטין.</string>
    <string name="gui_walkthrough_step4_mouse">זוהי תצוגת האנימציה. לחץ כדי להשהות/להפעיל, גרור כדי להזיז את המצלמה, והשתמש בגלגלת העכבר כדי להגדיל/להקטין.</string>
    <string name="gui_walkthrough_step5">בחר באפשרות זו כדי להגיע לתפריט התבניות. (אנא עשה זאת כדי להמשיך.)</string>
    <string name="gui_walkthrough_step6">בחר באפשרות זו כדי לפתוח את דיאגרמת הסולם. (אנא עשה זאת כדי להמשיך.)</string>
    <string name="gui_walkthrough_step7_touch">זוהי דיאגרמת הסולם. גרור את סמן הזמן למעלה ולמטה כדי לכוון את הזמן. ניתן גם להגדיל את הסולם באמצעות ג'סטת צביטה.</string>
    <string name="gui_walkthrough_step7_mouse">זוהי דיאגרמת הסולם. גרור את סמן הזמן למעלה ולמטה כדי לכוון את הזמן. ניתן גם להגדיל את הסולם באמצעות גלגלת העכבר.</string>
    <string name="gui_walkthrough_step8_touch">לחיצה ארוכה בתוך דיאגרמת הסולם תפתח אפשרויות עריכה.</string>
    <string name="gui_walkthrough_step8_mouse">לחיצה ימנית בתוך דיאגרמת הסולם תפתח אפשרויות עריכה.</string>
    <string name="gui_walkthrough_step9">זה מייצג מעבר, במקרה זה זריקה. בחר בו כדי להבליט אותו. (אנא עשה זאת כדי להמשיך.)</string>
    <string name="gui_walkthrough_step10">כאשר המעבר נבחר, תיבה זו מייצגת את מיקומו. גרור את התיבה כדי לשנות את מיקום האירוע.</string>
    <string name="gui_walkthrough_step11_touch">לחיצה ארוכה על המעבר תפתח אפשרויות עריכה נוספות.</string>
    <string name="gui_walkthrough_step11_mouse">לחיצה ימנית על המעבר תפתח אפשרויות עריכה נוספות.</string>
    <string name="gui_walkthrough_step12_touch">זה מייצג אירוע. גרור אותו למעלה ולמטה כדי לשנות את התזמון שלו, או לחץ לחיצה ארוכה לאפשרויות נוספות.</string>
    <string name="gui_walkthrough_step12_mouse">זה מייצג אירוע. גרור אותו למעלה ולמטה כדי לשנות את התזמון שלו, או לחץ לחיצה ימנית לאפשרויות נוספות.</string>
    <string name="gui_walkthrough_step13">בחר באפשרות זו כדי לסגור את דיאגרמת הסולם. (אנא עשה זאת כדי להמשיך.)</string>
    <string name="gui_walkthrough_step14">בחר בסמל רשימת התבניות כדי לפתוח רשימת תבניות. (אנא עשה זאת כדי להמשיך.)</string>
    <string name="gui_walkthrough_step15">זהו מסך הפתיחה של רשימות התבניות. בחלק העליון נמצאות הרשימות שנוצרו על ידך. צור ככל שתרצה ושתף אותן עם אחרים!</string>
    <string name="gui_walkthrough_step16">אלו הן רשימות התבניות המגיעות עם Juggling Lab. בחר ברשימה זו כדי לפתוח אותה. (אנא עשה זאת כדי להמשיך.)</string>
    <string name="gui_walkthrough_step17_touch">כל שורה היא תבנית נפרדת. בחר תבנית כדי להפעיל אנימציה, או לחץ לחיצה ארוכה לאפשרויות נוספות. התפריט בצד ימין למעלה מאפשר גישה לתכונות עבור הרשימה כולה.</string>
    <string name="gui_walkthrough_step17_mouse">כל שורה היא תבנית נפרדת. בחר תבנית כדי להפעיל אנימציה, או לחץ לחיצה ימנית לאפשרויות נוספות. התפריט בצד ימין למעלה מאפשר גישה לתכונות עבור הרשימה כולה.</string>
    <string name="gui_walkthrough_step18">בחר באפשרות זו כדי לסגור את רשימת התבניות ולטעון רשימה חדשה. (אנא עשה זאת כדי להמשיך.)</string>
    <string name="gui_walkthrough_step19">כאן מסתיים הסיור. אנו מקווים שתיהנה מ-Juggling Lab!</string>
