    <string name="gui_walkthrough_step4_mouse">ni li lukin pi musi tawa. o luka tawa awen/tawa, o tawa e ilo lukin, o sike e ilo sike tawa suli/lili.</string>
    <string name="gui_walkthrough_step5">o luka e ni tawa lukin e lipu pi musi tawa. (o pali e ni tawa kama.)</string>
    <string name="gui_walkthrough_step6">o luka e ni tawa open e sitelen leko. (o pali e ni tawa kama.)</string>
    <string name="gui_walkthrough_step7_touch">ni li sitelen leko. o tawa e ilo tenpo tawa sewi en anpa. sina ken suli e leko kepeken luka tu.</string>
    <string name="gui_walkthrough_step7_mouse">ni li sitelen leko. o tawa e ilo tenpo tawa sewi en anpa. sina ken suli e leko kepeken ilo sike.</string>
    <string name="gui_walkthrough_step8_touch">luka suli lon insa sitelen leko li open e ilo ante.</string>
    <string name="gui_walkthrough_step8_mouse">luka poka lon insa sitelen leko li open e ilo ante.</string>
    <string name="gui_walkthrough_step9">ni li sitelen e tawa ante (pana lon ni). o luka e ni tawa suno e ni. (o pali e ni tawa kama.)</string>
    <string name="gui_walkthrough_step10">tenpo pi luka ante, poki ni li sitelen e ma. o tawa e poki tawa ante e ma.</string>
    <string name="gui_walkthrough_step11_touch">luka suli lon tawa ante li open e ilo ante mute.</string>
    <string name="gui_walkthrough_step11_mouse">luka poka lon tawa ante li open e ilo ante mute.</string>
    <string name="gui_walkthrough_step12_touch">ni li sitelen e tenpo tawa. o tawa e ni tawa sewi en anpa tawa ante e tenpo, anu luka suli tawa ilo ante.</string>
    <string name="gui_walkthrough_step12_mouse">ni li sitelen e tenpo tawa. o tawa e ni tawa sewi en anpa tawa ante e tenpo, anu luka poka tawa ilo ante.</string>
    <string name="gui_walkthrough_step13">o luka e ni tawa pini e sitelen leko. (o pali e ni tawa kama.)</string>
    <string name="gui_walkthrough_step14">o luka e sitelen pi lipu musi tawa open e lipu musi. (o pali e ni tawa kama.)</string>
    <string name="gui_walkthrough_step15">ni li lipu open pi lipu musi. sewi ni li ma pi lipu musi sina. o pali e mute e pana tawa jan ante!</string>
    <string name="gui_walkthrough_step16">ni li lipu musi pi Juggling Lab. o luka e ni tawa open. (o pali e ni tawa kama.)</string>
    <string name="gui_walkthrough_step17_touch">sitelen linja wan li musi wan. o luka tawa open e musi tawa, anu luka suli tawa ante. lipu lon sewi poka li pana e ilo tawa lipu ali.</string>
    <string name="gui_walkthrough_step17_mouse">sitelen linja wan li musi wan. o luka tawa open e musi tawa, anu luka poka tawa ante. lipu lon sewi poka li pana e ilo tawa lipu ali.</string>
    <string name="gui_walkthrough_step18">o luka e ni tawa pini e lipu musi en tawa lipu sin. (o pali e ni tawa kama.)</string>
    <string name="gui_walkthrough_step19">ni li pini e lukin ma. mi wile e ni: sina pilin pona lon Juggling Lab!</string>
